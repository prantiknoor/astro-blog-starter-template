---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { Button } from '@/components/ui/button';
import { Card, CardHeader, CardTitle, CardContent, CardDescription, CardFooter } from '@/components/ui/card';
import { Input } from '@/components/ui/input';
import { Label } from '@/components/ui/label';
import { Textarea } from '@/components/ui/textarea';
import { actions } from 'astro:actions';

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect('/admin');
}

// Fetch the post from GitHub
console.log('--- FETCHING FROM GITHUB ---', slug);
const { data: post, error } = await Astro.callAction(actions.getPost, { slug });

if (error || !post) {
    console.error('--- GITHUB FETCH ERROR ---', error);
	return Astro.redirect('/admin');
}

// Prepare the date for the input[type="date"]
// Some markdown parsers return pubDate as a string, others as a Date object
const dateStr = post.data.pubDate instanceof Date 
    ? post.data.pubDate.toISOString().split('T')[0] 
    : String(post.data.pubDate).split('T')[0];
---


<AdminLayout title="Edit Post">
    <div class="mb-8">
        <a href="/admin" class="text-sm text-blue-600 hover:underline">← Back to Dashboard</a>
    </div>

    <Card>
        <CardHeader>
            <CardTitle>Edit Blog Post</CardTitle>
            <CardDescription>Update the details of your blog post.</CardDescription>
        </CardHeader>
        <form id="edit-post-form" method="POST">
            <input type="hidden" name="slug" value={slug} />
            <CardContent className="space-y-4">
                <div id="error-banner-global" class="hidden bg-red-50 border border-red-200 text-red-600 p-4 rounded text-sm mb-2">
                    <strong id="error-title">Error:</strong>
                    <div id="error-list-global" class="mt-1"></div>
                </div>

                <div class="space-y-2">
                    <Label htmlFor="title">Title</Label>
                    <Input id="title" name="title" defaultValue={post.data.title} required />
                    <div id="error-field-title" class="text-red-500 text-xs mt-1 hidden"></div>
                </div>

                <div class="space-y-2">
                    <Label htmlFor="description">Description</Label>
                    <Textarea id="description" name="description" defaultValue={post.data.description} required />
                    <div id="error-field-description" class="text-red-500 text-xs mt-1 hidden"></div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <Label htmlFor="pubDate">Publish Date</Label>
                        <Input id="pubDate" name="pubDate" type="date" defaultValue={dateStr} required />
                        <div id="error-field-pubDate" class="text-red-500 text-xs mt-1 hidden"></div>
                    </div>
                    <div class="space-y-2">
                        <Label htmlFor="heroImage">Upload Hero Image (Replaces current)</Label>
                        <input type="hidden" name="currentHeroImage" value={post.data.heroImage} />
                        {post.data.heroImage && (
                            <div class="text-xs text-gray-500 mb-1">
                                Current image: <span class="font-mono">{post.data.heroImage}</span>
                            </div>
                        )}
                        <Input id="heroImage" name="heroImage" type="file" accept="image/*" />
                        <div id="error-field-heroImage" class="text-red-500 text-xs mt-1 hidden"></div>
                    </div>

                </div>

                <div class="space-y-2">
                    <Label htmlFor="content">Content (Markdown)</Label>
                    <Textarea id="content" name="content" className="min-h-[300px]" defaultValue={post.body} required />
                    <div id="error-field-content" class="text-red-500 text-xs mt-1 hidden"></div>
                </div>
            </CardContent>
            <CardFooter className="flex justify-end space-x-2">
                <a href="/admin">
                    <Button variant="outline" type="button">Cancel</Button>
                </a>
                <Button type="submit" id="submit-btn">Update Post</Button>
            </CardFooter>
        </form>
    </Card>
</AdminLayout>


<script>
  import { actions } from 'astro:actions';

  const form = document.getElementById('edit-post-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const globalErrorBanner = document.getElementById('error-banner-global') as HTMLDivElement;
  const globalErrorList = document.getElementById('error-list-global') as HTMLDivElement;

  function resetErrors() {
    globalErrorBanner?.classList.add('hidden');
    if (globalErrorList) globalErrorList.innerHTML = '';
    
    document.querySelectorAll('[id^="error-field-"]').forEach(el => {
      el.classList.add('hidden');
      el.innerHTML = '';
    });
  }

  function showFieldError(field: string, msg: string) {
    const el = document.getElementById(`error-field-${field}`);
    if (el) {
      el.innerText = msg;
      el.classList.remove('hidden');
    }
  }

  function showGlobalError(msg: string) {
    if (globalErrorBanner && globalErrorList) {
      globalErrorList.innerText = msg;
      globalErrorBanner.classList.remove('hidden');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    console.log('--- STARTING UPDATE ACTION ---');
    
    resetErrors();

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerText = 'Updating...';
    }

    const formData = new FormData(form);
    
    try {
      const { data, error } = await actions.updatePost(formData);

      if (error) {
        console.error('Action Error:', error);
        
        let hasFieldErrors = false;
        const actionError = error as any;

        if (actionError.fields) {
            Object.entries(actionError.fields).forEach(([field, errors]) => {
                if (errors && Array.isArray(errors) && errors.length > 0) {
                    showFieldError(field, errors.join(', '));
                    hasFieldErrors = true;
                }
            });
        }
        
        if (!hasFieldErrors) {
            showGlobalError(actionError.message || 'An error occurred during update.');
        }

        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerText = 'Update Post';
        }
      } else {
        console.log('Action Success:', data);
        window.location.href = '/admin';
      }
    } catch (err: any) {
      console.error('Unexpected frontend error:', err);
      showGlobalError('An unexpected error occurred: ' + (err?.message || 'unknown'));
      
      if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.innerText = 'Update Post';
      }
    }
  });
</script>


